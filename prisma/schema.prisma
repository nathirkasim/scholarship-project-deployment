generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                   @id @default(uuid())
  email                    String                   @unique
  password_hash            String
  full_name                String
  phone                    String?
  role                     UserRole                 @default(student)
  is_active                Boolean                  @default(true)
  last_login               DateTime?
  created_at               DateTime                 @default(now())
  updated_at               DateTime                 @updatedAt
  status_logs              ApplicationStatusLog[]   @relation("ChangedBy")
  decided_applications     Application[]            @relation("DecidedBy")
  applications             Application[]
  notifications            Notification[]
  verification_assignments VerificationAssignment[] @relation("AssignedVerifier")
  field_reports            VerifierFieldReport[]

  @@map("users")
}

model ScholarshipProgram {
  id                   String                @id @default(uuid())
  program_name         String
  program_code         String                @unique
  academic_year        String
  description          String?
  total_seats          Int                   @default(100)
  shortlist_multiplier Decimal               @default(2.0) @db.Decimal(4, 2)
  application_start    DateTime
  application_end      DateTime
  is_active            Boolean               @default(true)
  created_by           String
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt
  applications         Application[]
  rule_overrides       ProgramRuleOverride[]

  @@map("scholarship_programs")
}

model StudentPersonal {
  id                       String           @id @default(uuid())
  user_id                  String           @unique
  date_of_birth            DateTime
  gender                   String
  aadhaar_last4            String?
  caste_category           CasteCategory    @default(General)
  religion_minority_status Boolean          @default(false)
  is_differently_abled     Boolean          @default(false)
  disability_type          String?
  disability_percentage    Int?
  is_first_graduate        Boolean          @default(false)
  father_status            String           @default("alive")
  mother_status            String           @default("alive")
  is_single_parent         Boolean          @default(false)
  is_orphan                Boolean          @default(false)
  guardian_name            String?
  guardian_annual_income   Decimal?         @db.Decimal(12, 2)
  residential_type         String           @default("urban")
  state                    String
  district                 String
  pincode                  String
  enrollment_status        EnrollmentStatus @default(active)
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  @@map("student_personal")
}

model StudentAcademic {
  id                          String      @id @default(uuid())
  user_id                     String      @unique
  hsc_percentage              Decimal     @db.Decimal(5, 2)
  hsc_board                   String?
  hsc_year                    Int?
  ug_aggregate_pct            Decimal?    @db.Decimal(5, 2)
  current_year_of_study       Int
  course_type                 String
  course_name                 String
  study_mode                  StudyMode   @default(full_time)
  active_arrears              Int         @default(0)
  institution_id              String
  receiving_other_scholarship Boolean     @default(false)
  other_scholarship_name      String?
  prev_awarded_by_trust       Boolean     @default(false)
  created_at                  DateTime    @default(now())
  updated_at                  DateTime    @updatedAt
  institution                 Institution @relation(fields: [institution_id], references: [id])

  @@map("student_academic")
}

model StudentFamily {
  id                      String   @id @default(uuid())
  user_id                 String   @unique
  family_size             Int
  earning_members         Int      @default(1)
  dependents              Int
  siblings_in_education   Int      @default(0)
  has_chronic_illness     Boolean  @default(false)
  chronic_illness_details String?
  mother_widow_pension    Boolean  @default(false)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@map("student_family")
}

model StudentFinancial {
  id                   String         @id @default(uuid())
  user_id              String         @unique
  total_annual_income  Decimal        @db.Decimal(12, 2)
  income_source        String?
  employment_status    String?
  ration_card_type     RationCardType @default(none)
  loan_outstanding     Decimal        @default(0) @db.Decimal(12, 2)
  annual_expenses      Decimal?       @db.Decimal(12, 2)
  gold_value_inr       Decimal        @default(0) @db.Decimal(12, 2)
  fixed_deposit_amount Decimal        @default(0) @db.Decimal(12, 2)
  created_at           DateTime       @default(now())
  updated_at           DateTime       @updatedAt

  @@map("student_financial")
}

model StudentAssets {
  id                String   @id @default(uuid())
  user_id           String   @unique
  total_asset_value Decimal  @default(0) @db.Decimal(12, 2)
  land_area_acres   Decimal  @default(0) @db.Decimal(8, 3)
  owns_land         Boolean  @default(false)
  vehicle_count     Int      @default(0)
  car_value         Decimal  @default(0) @db.Decimal(12, 2)
  electronics_value Decimal  @default(0) @db.Decimal(12, 2)
  property_count    Int      @default(0)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("student_assets")
}

model StudentHousing {
  id              String        @id @default(uuid())
  user_id         String        @unique
  house_type      HouseType     @default(pucca_owned)
  ownership_type  OwnershipType @default(owned)
  total_rooms     Int           @default(2)
  has_electricity Boolean       @default(true)
  has_piped_water Boolean       @default(true)
  has_toilet      Boolean       @default(true)
  has_lpg         Boolean       @default(true)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  @@map("student_housing")
}

model StudentGovtBenefits {
  id                  String   @id @default(uuid())
  user_id             String   @unique
  has_active_benefits Boolean  @default(false)
  has_bpl_card        Boolean  @default(false)
  has_aay_card        Boolean  @default(false)
  has_mgnrega         Boolean  @default(false)
  has_ayushman        Boolean  @default(false)
  has_pm_schemes      Boolean  @default(false)
  benefit_details     String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@map("student_govt_benefits")
}

model Institution {
  id                String            @id @default(uuid())
  name              String
  code              String            @unique
  type              String
  affiliation       String?
  is_recognized     Boolean           @default(true)
  state             String
  district          String
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  student_academics StudentAcademic[]

  @@map("institutions")
}

model Application {
  id                       String                  @id @default(uuid())
  program_id               String
  user_id                  String
  status                   ApplicationStatus       @default(draft)
  anomaly_score            Decimal?                @db.Decimal(4, 3)
  anomaly_flag             Boolean                 @default(false)
  anomaly_reasons          Json?
  anomaly_checked_at       DateTime?
  merit_score              Decimal?                @db.Decimal(6, 2)
  rule_need_score          Decimal?                @db.Decimal(6, 2)
  integrity_adj            Decimal?                @db.Decimal(6, 2)
  wsm_provisional          Decimal?                @db.Decimal(6, 2)
  composite_score          Decimal?                @db.Decimal(6, 2)
  composite_rank           Int?
  scored_at                DateTime?
  verification_match_score Decimal?                @db.Decimal(5, 2)
  post_verify_composite    Decimal?                @db.Decimal(6, 2)
  final_decision           FinalDecision?
  decided_by_id            String?
  decided_at               DateTime?
  rejection_reason         String?
  submitted_at             DateTime?
  created_at               DateTime                @default(now())
  updated_at               DateTime                @updatedAt
  status_logs              ApplicationStatusLog[]
  decided_by               User?                   @relation("DecidedBy", fields: [decided_by_id], references: [id])
  program                  ScholarshipProgram      @relation(fields: [program_id], references: [id])
  user                     User                    @relation(fields: [user_id], references: [id])
  documents                Document[]
  notifications            Notification[]
  verification_assignment  VerificationAssignment?

  @@unique([program_id, user_id])
  @@map("applications")
}

model ApplicationStatusLog {
  id             String             @id @default(uuid())
  application_id String
  from_status    ApplicationStatus?
  to_status      ApplicationStatus
  changed_by_id  String?
  reason         String?
  metadata       Json?
  created_at     DateTime           @default(now())
  application    Application        @relation(fields: [application_id], references: [id])
  changed_by     User?              @relation("ChangedBy", fields: [changed_by_id], references: [id])

  @@map("application_status_logs")
}

model Document {
  id             String         @id @default(uuid())
  application_id String
  doc_type       String
  original_name  String
  storage_key    String
  file_size_kb   Int
  mime_type      String
  status         DocumentStatus @default(pending)
  verified_by_id String?
  verified_at    DateTime?
  rejection_note String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  application    Application    @relation(fields: [application_id], references: [id])

  @@map("documents")
}

model EligibilityRule {
  id                String                @id @default(uuid())
  rule_code         String                @unique
  rule_name         String
  rule_description  String?
  domain            String
  rule_type         RuleType
  condition_field   String?
  condition_field_2 String?
  operator          RuleOperator          @default(EQ)
  default_value     Json
  value_type        ValueType             @default(number)
  score_bucket      ScoreBucket           @default(none)
  score_pts         Decimal?              @db.Decimal(6, 2)
  on_pass_action    String?
  on_fail_action    String?
  cross_references  String?
  is_active         Boolean               @default(true)
  sort_order        Int
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt
  program_overrides ProgramRuleOverride[]

  @@map("eligibility_rules")
}

model ProgramRuleOverride {
  id             String             @id @default(uuid())
  program_id     String
  rule_id        String
  override_value Json
  is_active      Boolean            @default(true)
  created_by     String
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  program        ScholarshipProgram @relation(fields: [program_id], references: [id])
  rule           EligibilityRule    @relation(fields: [rule_id], references: [id])

  @@unique([program_id, rule_id])
  @@map("program_rule_overrides")
}

model VerificationAssignment {
  id                    String               @id @default(uuid())
  application_id        String               @unique
  verifier_id           String
  priority_score        Decimal?             @db.Decimal(5, 2)
  verification_priority Int?
  status                VerificationStatus   @default(pending)
  assigned_at           DateTime             @default(now())
  due_date              DateTime?
  completed_at          DateTime?
  application           Application          @relation(fields: [application_id], references: [id])
  verifier              User                 @relation("AssignedVerifier", fields: [verifier_id], references: [id])
  field_reports         VerifierFieldReport?

  @@map("verification_assignments")
}

model VerifierFieldReport {
  id                            String                 @id @default(uuid())
  assignment_id                 String                 @unique
  verifier_id                   String
  gps_latitude                  Decimal?               @db.Decimal(10, 7)
  gps_longitude                 Decimal?               @db.Decimal(10, 7)
  gps_accuracy_meters           Int?
  sec_a_identity_match          Boolean?
  sec_a_photo_key               String?
  sec_a_notes                   String?
  sec_b_housing_type_confirmed  HouseType?
  sec_b_ownership_confirmed     OwnershipType?
  sec_b_house_photo_key         String?
  sec_b_notes                   String?
  sec_c_electricity             Boolean?
  sec_c_water                   Boolean?
  sec_c_toilet                  Boolean?
  sec_c_lpg                     Boolean?
  sec_c_notes                   String?
  sec_d_income_doc_present      Boolean?
  sec_d_occupation_matches      Boolean?
  sec_d_notes                   String?
  sec_e_vehicle_count_confirmed Int?
  sec_e_car_present             Boolean?
  sec_e_gold_visible            Boolean?
  sec_e_notes                   String?
  sec_f_electronics_present     Boolean?
  sec_f_electronics_value_est   Decimal?               @db.Decimal(10, 2)
  sec_f_notes                   String?
  sec_g_land_present            Boolean?
  sec_g_land_acres              Decimal?               @db.Decimal(8, 3)
  sec_g_notes                   String?
  sec_h_fd_docs_visible         Boolean?
  sec_h_savings_visible         Boolean?
  sec_h_notes                   String?
  sec_i_all_docs_present        Boolean?
  sec_i_docs_photo_key          String?
  sec_i_discrepancies           String?
  yes_count                     Int?
  total_fields                  Int?
  match_score                   Decimal?               @db.Decimal(5, 2)
  verifier_notes                String?
  submitted_at                  DateTime               @default(now())
  assignment                    VerificationAssignment @relation(fields: [assignment_id], references: [id])
  verifier                      User                   @relation(fields: [verifier_id], references: [id])

  @@map("verifier_field_reports")
}

model Notification {
  id             String       @id @default(uuid())
  user_id        String
  application_id String?
  type           String
  title          String
  message        String
  is_read        Boolean      @default(false)
  sent_via_email Boolean      @default(false)
  created_at     DateTime     @default(now())
  application    Application? @relation(fields: [application_id], references: [id])
  user           User         @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

enum UserRole {
  student
  verifier
  super_admin
}

enum ApplicationStatus {
  draft
  submitted
  evaluating
  anomaly_flagged
  not_shortlisted
  evaluated
  scored
  verification_pending
  verification_complete
  approved
  waitlisted
  rejected
}

enum RuleType {
  SCORE
  DEDUCTION
  COMPOSITE
  THRESHOLD
  AWARD
  CONFIG
}

enum RuleOperator {
  GT
  LT
  GTE
  LTE
  EQ
  NEQ
  IN
  NOT_IN
  AND_COMPOUND
  SCALE
  FORMULA
  ML_MODEL
  RANGE_CHECK
  CONFIG
  RANK_CUTOFF
  CONSTANT
}

enum ValueType {
  number
  boolean
  string
  json_array
  scale
  formula
  range
}

enum ScoreBucket {
  merit
  need
  integrity
  none
}

enum DocumentStatus {
  pending
  verified
  rejected
}

enum VerificationStatus {
  pending
  in_progress
  complete
  skipped
}

enum FinalDecision {
  approved
  rejected
  waitlisted
}

enum StudyMode {
  full_time
  part_time
  distance
}

enum EnrollmentStatus {
  active
  inactive
  on_leave
}

enum CasteCategory {
  SC
  ST
  OBC
  General
  NT
}

enum HouseType {
  kuccha
  semi_pucca
  pucca_rented
  pucca_owned
  flat_apartment
  homeless
}

enum OwnershipType {
  owned
  rented
  govt_allotted
  homeless
}

enum RationCardType {
  BPL
  AAY
  OPH
  none
}
