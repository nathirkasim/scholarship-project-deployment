# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=scholarship
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=scholarship_db
DATABASE_URL=postgresql://scholarship:change_me_strong_password@localhost:5432/scholarship_db

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change_me_256bit_random_secret_here
NEXTAUTH_SECRET=change_me_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ── MinIO ─────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_BUCKET=scholarship-docs
MINIO_USE_SSL=false

# ── ML Service ────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:5000
ML_ANOMALY_THRESHOLD=0.65

# ── Email (SMTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@yourscholarship.org

# ── App Config ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
